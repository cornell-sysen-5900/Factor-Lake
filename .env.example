# -------------------------------------------------------------
# Supabase Configuration
# -------------------------------------------------------------
# Your project's API URL (found in Project Settings -> API)
SUPABASE_URL="https://your-project-id.supabase.co"

# The SERVICE_ROLE key is required to bypass Row Level Security 
# and dynamically fetch the OpenAPI schema for archiving.
SUPABASE_KEY="your-service-role-secret-key"


# -------------------------------------------------------------
# GitHub Archiver Configuration (Optional)
# -------------------------------------------------------------
# Specify the exact GitHub repository to push releases to.
# If omitted, the script will use the current Git repository context.
# ARCHIVE_GITHUB_REPO="owner/repo-name"

# Explicitly define tables to archive (comma-separated).
# Only needed if OpenAPI schema exposition is disabled in your project.
# TABLES_TO_ARCHIVE="monthly_prices,iwm_constituents"
